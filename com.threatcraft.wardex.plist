<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.threatcraft.wardex</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/wardex</string>
        <string>start</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/wardex.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/wardex.err.log</string>
</dict>
</plist>